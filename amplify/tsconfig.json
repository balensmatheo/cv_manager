{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@aws-sdk/*": ["../node_modules/@aws-sdk/*"]
    }
  },
  "include": ["./**/*.ts"]
}
